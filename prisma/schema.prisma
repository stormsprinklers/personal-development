generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/** Full app snapshot (matches client `AppData` JSON). One row per sync key. */
model AppDataStore {
  syncKey   String   @id
  payload   Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
